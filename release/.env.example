HERZGARTEN_TAG=0.1.0
CORS_ORIGIN=https://example.com

POSTGRES_DB=herzgarten
POSTGRES_USER=herzgarten
POSTGRES_PASSWORD=replace-with-a-strong-database-password
DATABASE_URL=postgresql://herzgarten:replace-with-a-strong-database-password@db:5432/herzgarten

JWT_SECRET=replace-with-a-long-random-secret
ADMIN_JWT_SECRET=replace-with-another-long-random-secret
ADMIN_PASSWORD=replace-with-a-strong-admin-password
ADMIN_TOKEN_TTL=8h

PUSH_ENABLED=false
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
