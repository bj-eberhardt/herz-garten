{
  "name": "@herzgarten/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run db:migrate && tsx watch --clear-screen=false src/server.ts",
    "db:migrate": "tsx src/migrate.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "start:prod": "node dist/migrate.js && node dist/server.js"
  },
  "dependencies": {
    "@types/multer": "^2.1.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "image-size": "^2.0.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.1",
    "pg": "^8.22.0",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.13.2",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/web-push": "^3.6.4",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}
