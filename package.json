{
  "name": "herzgarten",
  "version": "0.1.9",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vue-tsc -b  && vite build",
    "lint": "eslint .",
